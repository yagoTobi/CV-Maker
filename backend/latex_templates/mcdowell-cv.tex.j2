%% McDowell CV Template
%% Generated by CV Maker

\documentclass[]{mcdowellcv}

\usepackage{amsmath}

\name{(( personal.fullName | latex_escape ))}
\address{(( personal.location | latex_escape ))}
\contacts{%
(% if personal.phone %)(( personal.phone | latex_escape ))(% endif -%)(% if personal.phone and personal.email %)\linebreak (% endif -%)(% if personal.email %)(( personal.email | latex_escape ))(% endif -%)(% for link in personal.links %)\linebreak (( link.label | latex_escape )): (( link.url ))(% endfor %)}

\begin{document}

\makeheader

(% if work %)
\begin{cvsection}{Employment}
(% for job in work %)
    \begin{cvsubsection}{(( job.title | latex_escape ))}{(( job.company | latex_escape ))}{(( job.startDate | latex_escape ))(% if job.endDate %)\,--\,(( job.endDate | latex_escape ))(% endif %)(% if job.location %)\,(( job.location | latex_escape ))(% endif %)}
(% if job.bullets %)
        \begin{itemize}
(% for bullet in job.bullets %)
            \item (( bullet | latex_escape ))
(% endfor %)
        \end{itemize}
(% endif %)
    \end{cvsubsection}
(% endfor %)
\end{cvsection}
(% endif %)

(% if education %)
\begin{cvsection}{Education}
(% for edu in education %)
    \begin{cvsubsection}{(( edu.location | latex_escape ))}{(( edu.school | latex_escape ))}{(( edu.startDate | latex_escape ))(% if edu.endDate %)\,--\,(( edu.endDate | latex_escape ))(% endif %)}
        \begin{itemize}
            \item (( edu.degree | latex_escape ))(% if edu.gpa %). GPA: (( edu.gpa | latex_escape ))(% endif %)
(% for detail in edu.details %)
            \item (( detail | latex_escape ))
(% endfor %)
        \end{itemize}
    \end{cvsubsection}
(% endfor %)
\end{cvsection}
(% endif %)

(% if projects %)
\begin{cvsection}{Technical Experience}
    \begin{cvsubsection}{Projects}{}{}
        \begin{itemize}
(% for proj in projects %)
            \item \textbf{(( proj.name | latex_escape ))} (% if proj.year %)(( proj.year | latex_escape ))(% endif %). (( proj.description | latex_escape ))(% if proj.technologies %)\,(( proj.technologies | latex_escape ))(% endif %)
(% endfor %)
        \end{itemize}
    \end{cvsubsection}
\end{cvsection}
(% endif %)

(% if skills %)
\begin{cvsection}{Skills}
    \begin{cvsubsection}{}{}{}
        \begin{itemize}
(% for cat in skills %)
            \item \textbf{(( cat.category | latex_escape )):} (( cat.skills | join('; ') | latex_escape ))
(% endfor %)
        \end{itemize}
    \end{cvsubsection}
\end{cvsection}
(% endif %)

(% if awards %)
\begin{cvsection}{Additional Experience and Awards}
    \begin{cvsubsection}{}{}{}
        \begin{itemize}
(% for award in awards %)
            \item \textbf{(( award.year | latex_escape )): (( award.title | latex_escape ))}(% if award.description %): (( award.description | latex_escape ))(% endif %)
(% endfor %)
        \end{itemize}
    \end{cvsubsection}
\end{cvsection}
(% endif %)

\end{document}
