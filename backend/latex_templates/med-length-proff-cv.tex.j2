\usepackage{ragged2e}
\hypersetup{
  colorlinks=true,
  linkcolor=darkblue,
  citecolor=darkblue,
  filecolor=darkblue,
  urlcolor=darkblue
}
\usepackage{xcolor}
\definecolor{darkblue}{RGB}{21, 88, 176}

\name{(( personal.fullName | latex_escape ))}
(% if personal_items %)
\address{%
(% for item in personal_items -%)(% if item.url -%)\href{(( item.url | latex_url_escape ))}{(( item.value | latex_escape ))}(% else -%)(( item.value | latex_escape ))(% endif -%)(% if not loop.last %)\enspace{}|\enspace{}(% endif -%)(% endfor %)}
(% endif %)

\begin{document}

(% if personal.summary %)
\begin{rSection}{Summary}
(( personal.summary | latex_escape ))
\end{rSection}

(% endif %)
(% for _sec in section_order %)

(% if _sec == 'work' and work %)
\begin{rSection}{(( section_labels['work'] | latex_escape ))}
(% for job in work %)
    \begin{rSubsection}{(( job.company | latex_escape ))}{\textbf{(( job.startDate | latex_escape ))(% if job.endDate %)\,--\,(( job.endDate | latex_escape ))(% endif %)}}{(( job.title | latex_escape ))}{(( job.location | latex_escape ))}
(% if job.bullets %)
(% for bullet in job.bullets %)
    \item (( bullet | html_latex ))
(% endfor %)
(% endif %)
    \end{rSubsection}
(% endfor %)
\end{rSection}

(% elif _sec == 'education' and education %)
\begin{rSection}{(( section_labels['education'] | latex_escape ))}
(% for edu in education %)
(% set has_items = edu.gpa or edu.details %)
(% if has_items %)
    \begin{rSubsection}{(( edu.school | latex_escape ))}{\textbf{(( edu.startDate | latex_escape ))(% if edu.endDate %)\,--\,(( edu.endDate | latex_escape ))(% endif %)}}{(( edu.degree | latex_escape ))}{(( edu.location | latex_escape ))}
(% if edu.gpa %)
    \item GPA: (( edu.gpa | latex_escape ))
(% endif %)
(% for detail in edu.details %)
    \item (( detail | html_latex ))
(% endfor %)
    \end{rSubsection}
(% else %)
    \textbf{(( edu.school | latex_escape ))} \hfill \textbf{(( edu.startDate | latex_escape ))(% if edu.endDate %)\,--\,(( edu.endDate | latex_escape ))(% endif %)}\\
    \textit{(( edu.degree | latex_escape ))} \hfill \textit{(( edu.location | latex_escape ))}
    \vspace{0.5em}
(% endif %)
(% endfor %)
\end{rSection}

(% elif _sec == 'skills' and skills %)
\begin{rSection}{(( section_labels['skills'] | latex_escape ))}
    \begin{tabular}{@{} >{\bfseries}l @{\hspace{2ex}} p{\dimexpr\textwidth-4.5cm\relax} @{}}
(% for cat in skills %)
        (( cat.category | latex_escape )): & (( cat.skills | join(', ') | latex_escape )) \\
(% endfor %)
    \end{tabular}
\end{rSection}

(% elif _sec == 'projects' and projects %)
\begin{rSection}{(( section_labels['projects'] | latex_escape ))}
(% for proj in projects %)
    \textbf{(( proj.name | latex_escape ))} (% if proj.year %)\hfill (( proj.year | latex_escape ))(% endif %)\\
    (( proj.description | latex_escape ))(% if proj.technologies %)\\ \textit{(( proj.technologies | latex_escape ))}(% endif %)
    (% if proj.bullets %)
    \begin{list}{$\cdot$}{\leftmargin=1em}
    \setlength{\itemsep}{-0.4em} \vspace{-0.4em}
    (% for bullet in proj.bullets %)
    \item (( bullet | html_latex ))
    (% endfor %)
    \end{list}
    (% endif %)
    \vspace{0.5em}
(% endfor %)
\end{rSection}

(% elif _sec == 'awards' and awards %)
\begin{rSection}{(( section_labels['awards'] | latex_escape ))}
    \begin{tabular}{@{} l @{\hspace{2ex}} p{\dimexpr\textwidth-3cm\relax} @{}}
(% for award in awards %)
        (( award.year | latex_escape )) & (( award.title | latex_escape ))(% if award.description %): (( award.description | latex_escape ))(% endif %) \\
(% endfor %)
    \end{tabular}
\end{rSection}

(% elif _sec.startswith('additional-') %)
(% set idx = _sec.split('-')[1] | int %)
(% if idx < additional_sections | length %)
(% set asec = additional_sections[idx] %)
\begin{rSection}{(( asec.title | latex_escape ))}
(% for entry in asec.entries %)
(% set has_items = entry.bullets or entry.description %)
(% if has_items %)
    \begin{rSubsection}{(( entry.title | latex_escape ))}{(% if entry.startDate %)\textbf{(( entry.startDate | latex_escape ))(% if entry.endDate %)\,--\,(( entry.endDate | latex_escape ))(% endif %)}(% endif %)}{(( entry.subtitle | default('') | latex_escape ))}{(( entry.location | default('') | latex_escape ))}
(% if entry.description %)
    \item (( entry.description | latex_escape ))
(% endif %)
(% for bullet in entry.bullets %)
    \item (( bullet | html_latex ))
(% endfor %)
    \end{rSubsection}
(% else %)
    \textbf{(( entry.title | latex_escape ))} (% if entry.startDate %)\hfill \textbf{(( entry.startDate | latex_escape ))(% if entry.endDate %)\,--\,(( entry.endDate | latex_escape ))(% endif %)}(% endif %)\\
    (% if entry.subtitle %)\textit{(( entry.subtitle | latex_escape ))} (% endif %)(% if entry.location %)\hfill \textit{(( entry.location | latex_escape ))}(% endif %)
    \vspace{0.5em}
(% endif %)
(% endfor %)
\end{rSection}
(% endif %)

(% endif %)
(% endfor %)

