# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AWS Configuration (uses default credential chain if not set)
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# Storage Backend: "file" (default, JSON files) or "dynamodb"
STORAGE_BACKEND=file

# DynamoDB Configuration (only used when STORAGE_BACKEND=dynamodb)
DYNAMODB_TABLE_NAME=cv-maker
# Set endpoint URL for DynamoDB Local; omit for real AWS DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:8100
